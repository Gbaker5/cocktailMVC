<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://kit.fontawesome.com/d7ccb43ad1.js" crossorigin="anonymous"></script>
    <title>Pour Decisions</title>
</head>
<body>
    <div class="container">

   <nav class="mobilenav">
        <a href="/logout">Logout</a>
   </nav>

    <nav class="topNav">
        <a class="navactive" href="/home">Home</a>
        <a href="/myLists">My Lists</a>
        <a href="/favorites">Favorites</a>
        <a class="logout" href="/logout">Logout</a>
    </nav>
     

    <div class="header">
        <h1>Pour Decisions</h1>
        <span>Looking for A Cocktail?</span>
        <span>Choose The First Letter of the Drink Name:</span>
    </div>
    

    <nav>
        
        <ul>
            <a class="letter" href="/letter/a">A</a>
            <a class="letter" href="/letter/b">B</a>
            <a class="letter" href="/letter/c">C</a>
            <a class="letter" href="/letter/d">D</a>
            <a class="letter" href="/letter/e">E</a>
            <a class="letter" href="/letter/f">F</a>  
            <a class="letter" href="/letter/g">G</a>
            <a class="letter" href="/letter/h">H</a>
            <a class="letter" href="/letter/i">I</a>
            <a class="letter" href="/letter/j">J</a>
            <a class="letter" href="/letter/k">K</a>
            <a class="letter" href="/letter/l">L</a>
            <a class="letter" href="/letter/m">M</a>
            <a class="letter" href="/letter/n">N</a>
            <a class="letter" href="/letter/o">O</a>
            <a class="letter" href="/letter/p">P</a>
            <a class="letter" href="/letter/q">Q</a>
            <a class="letter" href="/letter/r">R</a>
            <a class="letter" href="/letter/s">S</a>
            <a class="letter" href="/letter/t">T</a>
            <a class="letter" href="/letter/u">U</a>
            <a class="letter" href="/letter/v">V</a>
            <a class="letter" href="/letter/w">W</a>
            <a class="letter" href="/letter/x">X</a>
            <a class="letter" href="/letter/y">Y</a>
            <a class="letter" href="/letter/z">Z</a>
        </ul>             

            
        
    </nav>

    <div class="ingredient-ct">
        <ul class="ingspans">
            <li><span>Or Choose an Ingredient:  If we have it, we'll serve it!</span></li>
           <!--- <li><span></span></li>-->
        </ul>

         <ul class="inginputs">
            <form action="/ingredient" method="GET">
            <input type="text" id="ingredientInput" name="ingredient">
            <button type="submit">Search By Ingredient</button>
            </form>
        </ul> 
        

        <button id="toggleIngredients" class="ingButtons">Show Common Ingredients</button>

        <div class="ingredientBoxes">
            <ul class="ingLeft">
                <%for(let i=0; i<ingredientsOne.length; i++){%>
                    <li>
                        <form action="/ingredient/<%=ingredientsOne[i]%>" method="GET">
                            <button type="submit" class="ingButtons"><%= ingredientsOne[i] %></button>
                        </form>
                        
                    </li>
                <%}%>
            </ul>
            <ul class="ingRight">
                <%for(let j=0; j<ingredientsTwo.length; j++){%>
                    <li>
                        <form action="/ingredient/<%=ingredientsTwo[j]%>" method="GET">
                            <button type="submit" class="ingButtons"><%= ingredientsTwo[j] %></button>
                        </form>
                    </li>
                <%}%>
            </ul>
        </div>
        
    </div>

    <div class="numDrinks-ct">
        <p class="numDrinks"></p>
    </div>

    <div class="cocktails-ct">
        <div id="cocktail-scrollbox">

            <div id="loader" class="cocktail-loader" style="display:none">
                <div class="loader-glass">
                <div class="loader-liquid"></div>
                
                <!-- Bubbles -->
                <div class="bubble b1"></div>
                <div class="bubble b2"></div>
                <div class="bubble b3"></div>
                <div class="bubble b4"></div>
                <div class="bubble b5"></div>
                
                <div class="loader-stem"></div>
                <div class="loader-base"></div>
                </div>
                <p>Mixing your cocktail…</p>
            </div>

           

        </div>
    </div>

    <div class="footer">
        <p>Made with API from <a href="https://www.thecocktaildb.com/">The Cocktail DB</a></p>
    </div>
    </div>

    <script src="/js/main.js"></script>
    


</body>
</html>